{{#if (or page.previous page.next)}}
<nav class="pagination">
  {{#with page.previous}}
  <span class="prev"><a href="{{{relativize ./url}}}">&#8249; Prev: {{{./content}}}</a></span>
  {{/with}}
  {{#with page.next}}
  <span class="next"><a href="{{{relativize ./url}}}">Next: {{{./content}}} &#8250;</a></span>
  {{/with}}
</nav>
{{/if}}
